{
  "name": "@gift-ai/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc && cp -R src/llm/prompts dist/llm/prompts",
    "test": "vitest run src/training/tests",
    "test:watch": "vitest src/training/tests",
    "seed": "tsx src/seed.ts",
    "content": "tsx --env-file=.env src/content.ts",
    "export-analytics": "tsx --env-file=.env src/export-analytics.ts",
    "export-chats": "tsx --env-file=.env src/export-chats.ts",
    "export-conversations": "tsx --env-file=.env src/export-conversations.ts",
    "csv-to-conversations": "tsx scripts/csv-messages-to-json.ts",
    "export-actions": "tsx --env-file=.env src/export-actions.ts",
    "setup-rop-alerts": "tsx --env-file=.env scripts/setup-rop-alerts.ts",
    "tune-cso-bot": "tsx --env-file=.env scripts/tune-cso-bot.ts",
    "bootstrap-rop-alerts": "tsx --env-file=.env scripts/bootstrap-rop-alerts.ts",
    "export-managers": "tsx --env-file=.env src/export-managers.ts",
    "create-actions-sheet": "tsx --env-file=.env scripts/create-actions-sheet.ts",
    "create-chat-sheet": "tsx --env-file=.env scripts/create-chat-sheet.ts",
    "test-bitrix-country": "tsx --env-file=.env src/test-bitrix-country.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.3",
    "better-sqlite3": "^11.9.1",
    "fflate": "^0.8.2",
    "hono": "^4.7.10",
    "tsx": "^4.19.4",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
